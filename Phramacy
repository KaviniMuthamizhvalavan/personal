# services/sale_service.py

import uuid
from data.datastore import datastore
from models.sale import Sale
from utils.validator import check_stock

class SaleService:
    def create_sale(self, customer_id, medicine_id, quantity):
        customer = datastore["customers"].get(customer_id)
        medicine = datastore["medicines"].get(medicine_id)
        
        if not customer or not medicine:
            raise ValueError("Customer or Medicine not found")
        
        if not check_stock(medicine, quantity):
            raise ValueError("Insufficient stock")

        medicine.quantity -= quantity
        total_amount = medicine.price * quantity
        sale_id = str(uuid.uuid4())
        sale = Sale(sale_id, customer_id, medicine_id, quantity, total_amount)
        datastore["sales"][sale_id] = sale
        return sale

    def get_sale(self, sale_id):
        return datastore["sales"].get(sale_id)

    def delete_sale(self, sale_id):
        if sale_id in datastore["sales"]:
            del datastore["sales"][sale_id]
            return True
        return False

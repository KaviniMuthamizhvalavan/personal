def main():
    system = PharmacySystem()

    customer = Customer(id=1, name="Alice", age=30, prescription="Ibuprofen 400mg")
    system.customer_service.add_customer(customer)

    medicine = Medicine(id=101, name="Ibuprofen", type="Painkiller", price=5.50, quantity=100)
    system.medicine_service.add_medicine(medicine)

    try:
        sale = system.sale_service.create_sale(customer_id=1, medicine_id=101, quantity=2)
        print(f"Sale created! Sale ID: {sale.id}, Total: ${sale.total_amount}")
        print(f"Remaining stock for {medicine.name}: {medicine.quantity}")
    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()

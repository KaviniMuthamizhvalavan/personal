import pytest
from models.customer import Customer
from models.medicine import Medicine
from services.customer_service import CustomerService
from services.medicine_service import MedicineService
from services.sale_service import SaleService
from data.datastore import datastore

@pytest.fixture(autouse=True)
def reset_datastore():
    datastore["customers"].clear()
    datastore["medicines"].clear()
    datastore["sales"].clear()

def test_create_sale():
    cust_service = CustomerService()
    med_service = MedicineService()
    sale_service = SaleService()
    
    customer = Customer(1, "John", 30)
    medicine = Medicine(10, "Cough Syrup", "Liquid", 10.0, 5)
    cust_service.add_customer(customer)
    med_service.add_medicine(medicine)
    
    sale = sale_service.create_sale(1, 10, 2)
    
    assert sale.total_amount == 20.0
    assert datastore["medicines"][10].quantity == 3
    assert sale.id in datastore["sales"]

def test_create_sale_insufficient_stock():
    cust_service = CustomerService()
    med_service = MedicineService()
    sale_service = SaleService()
    
    customer = Customer(2, "Jane", 28)
    medicine = Medicine(11, "Drops", "Liquid", 5.0, 1)
    cust_service.add_customer(customer)
    med_service.add_medicine(medicine)
    
    with pytest.raises(ValueError, match="Insufficient stock"):
        sale_service.create_sale(2, 11, 2)

def test_get_and_delete_sale():
    cust_service = CustomerService()
    med_service = MedicineService()
    sale_service = SaleService()
    
    customer = Customer(3, "Doe", 40)
    medicine = Medicine(12, "Pills", "Tablet", 2.0, 10)
    cust_service.add_customer(customer)
    med_service.add_medicine(medicine)
    
    sale = sale_service.create_sale(3, 12, 1)
    fetched = sale_service.get_sale(sale.id)
    assert fetched.id == sale.id
    
    assert sale_service.delete_sale(sale.id) is True
    assert sale_service.get_sale(sale.id) is None

import os
from services.registration_service import RegistrationService
from exceptions.custom_exceptions import (
    CourseNotFoundException, StudentNotFoundException, 
    CourseFullException, FileDataNotFoundException
)

def main():
    service = RegistrationService()

    # Ensure data directory exists
    os.makedirs('data', exist_ok=True)
    if not os.path.exists('data/courses.csv'):
        with open('data/courses.csv', 'w') as f:
            f.write("course_id,course_name,instructor,seats_available\n")
    if not os.path.exists('data/students.csv'):
        with open('data/students.csv', 'w') as f:
            f.write("student_id,name,email,enrolled_courses\n")

    while True:
        print("\n===== Student Course Registration System =====")
        print("1 View Courses")
        print("2 Add Course")
        print("3 Register Student")
        print("4 Enroll Course")
        print("5 Drop Course")
        print("6 Exit")
        
        choice = input("Enter your choice: ")

        try:
            if choice == '1':
                courses = service.get_all_courses()
                for c in courses.values():
                    print("-" * 20)
                    print(c)
            elif choice == '2':
                c_id = input("Enter Course ID: ")
                c_name = input("Enter Course Name: ")
                inst = input("Enter Instructor: ")
                seats = input("Enter Available Seats: ")
                service.add_course(c_id, c_name, inst, seats)
                print("Course added successfully.")
            elif choice == '3':
                s_id = input("Enter Student ID: ")
                name = input("Enter Name: ")
                email = input("Enter Email: ")
                msg = service.register_student(s_id, name, email)
                print(msg)
            elif choice == '4':
                s_id = input("Enter Student ID: ")
                c_id = input("Enter Course ID: ")
                msg = service.enroll_course(s_id, c_id)
                print(msg)
            elif choice == '5':
                s_id = input("Enter Student ID: ")
                c_id = input("Enter Course ID: ")
                msg = service.drop_course(s_id, c_id)
                print(msg)
            elif choice == '6':
                print("Exiting...")
                break
            else:
                print("Invalid choice.")
        except (CourseNotFoundException, StudentNotFoundException, 
                CourseFullException, FileDataNotFoundException) as e:
            print(str(e))

if __name__ == "__main__":
    main()

# exceptions/custom_exceptions.py

class CourseNotFoundException(Exception):
    pass

class StudentNotFoundException(Exception):
    pass

class CourseFullException(Exception):
    pass

class FileDataNotFoundException(Exception):
    pass
# models/course.py

class Course:
    def __init__(self, course_id, course_name, instructor, seats_available):
        self.course_id = course_id
        self.course_name = course_name
        self.instructor = instructor
        self.seats_available = int(seats_available)

    def decrease_seats(self):
        if self.seats_available > 0:
            self.seats_available -= 1
            return True
        return False

    def increase_seats(self):
        self.seats_available += 1

    def __str__(self):
        return (f"Course ID: {self.course_id}\n"
                f"Course Name: {self.course_name}\n"
                f"Instructor: {self.instructor}\n"
                f"Seats Available: {self.seats_available}")


# models/student.py

class Student:
    def __init__(self, student_id, name, email, enrolled_courses=None):
        self.student_id = student_id
        self.name = name
        self.email = email
        self.enrolled_courses = enrolled_courses if enrolled_courses else []

    def enroll(self, course_id):
        if course_id not in self.enrolled_courses:
            self.enrolled_courses.append(course_id)

    def drop(self, course_id):
        if course_id in self.enrolled_courses:
            self.enrolled_courses.remove(course_id)
# utils/file_handler.py
import csv
import os
from models.course import Course
from models.student import Student
from exceptions.custom_exceptions import FileDataNotFoundException

class FileHandler:
    @staticmethod
    def load_courses(filepath):
        if not os.path.exists(filepath):
            raise FileDataNotFoundException("Error: Course data file not found")
        courses = {}
        with open(filepath, mode='r', newline='') as file:
            reader = csv.DictReader(file)
            for row in reader:
                courses[row['course_id'].strip()] = Course(
                    row['course_id'].strip(),
                    row['course_name'].strip(),
                    row['instructor'].strip(),
                    row['seats_available'].strip()
                )
        return courses

    @staticmethod
    def save_courses(filepath, courses):
        with open(filepath, mode='w', newline='') as file:
            writer = csv.writer(file)
            writer.writerow(['course_id', 'course_name', 'instructor', 'seats_available'])
            for course in courses.values():
                writer.writerow([course.course_id, course.course_name, course.instructor, course.seats_available])

    @staticmethod
    def load_students(filepath):
        if not os.path.exists(filepath):
            raise FileDataNotFoundException("Error: Student data file not found")
        students = {}
        with open(filepath, mode='r', newline='') as file:
            reader = csv.DictReader(file)
            for row in reader:
                courses_str = row['enrolled_courses'].strip()
                enrolled_courses = courses_str.split(';') if courses_str else []
                students[row['student_id'].strip()] = Student(
                    row['student_id'].strip(),
                    row['name'].strip(),
                    row['email'].strip(),
                    enrolled_courses
                )
        return students

    @staticmethod
    def save_students(filepath, students):
        with open(filepath, mode='w', newline='') as file:
            writer = csv.writer(file)
            writer.writerow(['student_id', 'name', 'email', 'enrolled_courses'])
            for student in students.values():
                courses_joined = ';'.join(student.enrolled_courses)
                writer.writerow([student.student_id, student.name, student.email, courses_joined])
# services/registration_service.py
from utils.file_handler import FileHandler
from models.course import Course
from models.student import Student
from exceptions.custom_exceptions import (
    CourseNotFoundException, StudentNotFoundException, 
    CourseFullException, FileDataNotFoundException
)

class RegistrationService:
    def __init__(self, courses_file='data/courses.csv', students_file='data/students.csv'):
        self.courses_file = courses_file
        self.students_file = students_file

    def get_all_courses(self):
        return FileHandler.load_courses(self.courses_file)

    def add_course(self, course_id, name, instructor, seats):
        try:
            courses = FileHandler.load_courses(self.courses_file)
        except FileDataNotFoundException:
            courses = {}
        
        courses[course_id] = Course(course_id, name, instructor, seats)
        FileHandler.save_courses(self.courses_file, courses)

    def register_student(self, student_id, name, email):
        try:
            students = FileHandler.load_students(self.students_file)
        except FileDataNotFoundException:
            students = {}
            
        students[student_id] = Student(student_id, name, email)
        FileHandler.save_students(self.students_file, students)
        return "Student registered successfully"

    def enroll_course(self, student_id, course_id):
        courses = FileHandler.load_courses(self.courses_file)
        students = FileHandler.load_students(self.students_file)

        if student_id not in students:
            raise StudentNotFoundException("Error: Student not found")
        if course_id not in courses:
            raise CourseNotFoundException("Error: Course not found")
        
        course = courses[course_id]
        student = students[student_id]

        if course.seats_available <= 0:
            raise CourseFullException("Enrollment failed: No seats available")
        
        if course_id in student.enrolled_courses:
            return "Student already enrolled in this course."

        course.decrease_seats()
        student.enroll(course_id)

        FileHandler.save_courses(self.courses_file, courses)
        FileHandler.save_students(self.students_file, students)
        
        return "Course enrollment successful"

    def drop_course(self, student_id, course_id):
        courses = FileHandler.load_courses(self.courses_file)
        students = FileHandler.load_students(self.students_file)

        if student_id not in students:
            raise StudentNotFoundException("Error: Student not found")
        if course_id not in courses:
            raise CourseNotFoundException("Error: Course not found")

        course = courses[course_id]
        student = students[student_id]

        if course_id in student.enrolled_courses:
            student.drop(course_id)
            course.increase_seats()
            FileHandler.save_courses(self.courses_file, courses)
            FileHandler.save_students(self.students_file, students)
            return "Course dropped successfully"
        else:
            return "Student is not enrolled in this course."

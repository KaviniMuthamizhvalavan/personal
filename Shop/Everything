from exceptions.cart_exceptions import OutOfStockError

class Cart:
    def __init__(self):
        # Stores items added by users
        self.items = {}

    def add_product(self, product, quantity: int):
        if product.quantity < quantity:
            raise OutOfStockError(f"Only {product.quantity} units of {product.name} available.")
        
        if product.name in self.items:
            self.items[product.name]['qty'] += quantity
        else:
            self.items[product.name] = {'product': product, 'qty': quantity}
        
        product.quantity -= quantity

    def remove_product(self, product_name: str):
        if product_name in self.items:
            del self.items[product_name]

    def view_cart(self):
        return {name: item_info['qty'] for name, item_info in self.items.items()}



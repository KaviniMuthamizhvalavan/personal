from exceptions.cart_exceptions import ProductNotFoundError

class StoreService:
    def __init__(self):
        self.inventory = {}

    def add_product(self, name: str, price: float, quantity: int):
        self.inventory[name] = Product(name, price, quantity)

    def get_product(self, name: str):
        if name not in self.inventory:
            raise ProductNotFoundError(f"Product '{name}' not found in store.")
        return self.inventory[name]

from utils.file_handler import save_order

class CartService:
    @staticmethod
    def checkout(user):
        if not user.cart.items:
            return False
        
        # Saves the order via the utility function
        save_order(user.cart)
        # Clear cart after successful checkout
        user.cart.items = {}
        return True

import os

def save_order(cart):
    # Ensure data directory exists
    os.makedirs("data", exist_ok=True)
    
    with open("data/order_history.txt", "a") as f:
        f.write(str(cart.view_cart()) + "\n")





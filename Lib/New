class BookNotFoundException(Exception):
    pass

class BookAlreadyBorrowedException(Exception):
    pass

class MemberNotFoundException(Exception):
    pass

class FileNotFoundException(Exception):
    pass
    
class BookNotBorrowedByMemberException(Exception):
    pass
class Book:
    def __init__(self, book_id, title, author, category, status="Available"):
        self.book_id = str(book_id)
        self.title = title
        self.author = author
        self.category = category
        self.status = status

    def to_csv_string(self):
        return f"{self.book_id},{self.title},{self.author},{self.category},{self.status}\n"
class Member:
    def __init__(self, member_id, name, email, borrowed_books=None):
        self.member_id = str(member_id)
        self.name = name
        self.email = email
        # Store borrowed books as a list of strings
        if isinstance(borrowed_books, str) and borrowed_books:
            self.borrowed_books = borrowed_books.split(';')
        elif borrowed_books:
            self.borrowed_books = borrowed_books
        else:
            self.borrowed_books = []

    def to_csv_string(self):
        books_str = ";".join(self.borrowed_books)
        return f"{self.member_id},{self.name},{self.email},{books_str}\n"

# tests/test_library.py
import pytest
import os
from services.library_service import LibraryService
from exceptions.custom_exceptions import (
    BookNotFoundException,
    BookAlreadyBorrowedException,
    MemberNotFoundException,
    FileNotFoundException,
    BookNotBorrowedByMemberException
)
from utils import file_handler

# Implementing TC01 to TC10 based on the Library Management System Test Suite[span_0](start_span)[span_0](end_span)

@pytest.fixture
def setup_library():
    """Precondition setup for tests[span_1](start_span)[span_1](end_span)."""
    service = LibraryService()
    file_handler.BOOKS_FILE = "data/test_books.csv"
    file_handler.MEMBERS_FILE = "data/test_members.csv"
    file_handler.ensure_data_dir()
    
    # Clear files before each test
    open(file_handler.BOOKS_FILE, 'w').close()
    open(file_handler.MEMBERS_FILE, 'w').close()
    
    # Add initial data
    service.add_book("101", "Python Programming", "John Smith", "Programming")
    service.register_member("M001", "Ravi Kumar", "ravi@gmail.com")
    
    yield service
    
    # Clean up test files after tests run
    if os.path.exists(file_handler.BOOKS_FILE):
        os.remove(file_handler.BOOKS_FILE)
    if os.path.exists(file_handler.MEMBERS_FILE):
        os.remove(file_handler.MEMBERS_FILE)

def test_tc01_view_books(setup_library, capsys):
    """TC01: View all books[span_2](start_span)[span_2](end_span)."""
    setup_library.view_books()
    captured = capsys.readouterr()
    assert "Available Books" in captured.out
    assert "101" in captured.out

def test_tc02_add_book(setup_library):
    """TC02: Add a new book[span_3](start_span)[span_3](end_span)."""
    setup_library.add_book("102", "Data Science", "Jane Miller", "DS")
    books = setup_library._get_books()
    assert len(books) == 2
    assert books[1].book_id == "102"

def test_tc03_register_member(setup_library):
    """TC03: Register a new member[span_4](start_span)[span_4](end_span)."""
    setup_library.register_member("M002", "Alice", "alice@test.com")
    members = setup_library._get_members()
    assert len(members) == 2
    assert members[1].member_id == "M002"

def test_tc04_borrow_book_valid(setup_library):
    """TC04: Borrow book (Available)[span_5](start_span)[span_5](end_span)."""
    setup_library.borrow_book("M001", "101")
    book = setup_library._get_books()[0]
    assert book.status == "Borrowed"

def test_tc05_borrow_book_already_borrowed(setup_library):
    """TC05: Borrow book (Already borrowed)[span_6](start_span)[span_6](end_span)."""
    setup_library.borrow_book("M001", "101")
    with pytest.raises(BookAlreadyBorrowedException):
        setup_library.borrow_book("M001", "101")

def test_tc06_borrow_book_invalid_book_id(setup_library):
    """TC06: Borrow book (Invalid Book ID)[span_7](start_span)[span_7](end_span)."""
    with pytest.raises(BookNotFoundException):
        setup_library.borrow_book("M001", "999")

def test_tc07_borrow_book_invalid_member_id(setup_library):
    """TC07: Borrow book (Invalid Member ID)[span_8](start_span)[span_8](end_span)."""
    with pytest.raises(MemberNotFoundException):
        setup_library.borrow_book("M999", "101")

def test_tc08_return_book_valid(setup_library):
    """TC08: Return borrowed book[span_9](start_span)[span_9](end_span)."""
    setup_library.borrow_book("M001", "101")
    setup_library.return_book("M001", "101")
    book = setup_library._get_books()[0]
    assert book.status == "Available"

def test_tc09_return_book_not_borrowed(setup_library):
    """TC09: Return book not borrowed by member[span_10](start_span)[span_10](end_span)."""
    with pytest.raises(BookNotBorrowedByMemberException):
        setup_library.return_book("M001", "101")

def test_tc10_data_file_missing(setup_library):
    """TC10: Books/Members file missing[span_11](start_span)[span_11](end_span)."""
    os.remove(file_handler.BOOKS_FILE)
    with pytest.raises(FileNotFoundException):
        setup_library.view_books()

from models.book import Book
from models.member import Member
from utils.file_handler import read_data, write_data, BOOKS_FILE, MEMBERS_FILE
from exceptions.custom_exceptions import *

class LibraryService:
    def _get_books(self):
        raw_data = read_data(BOOKS_FILE)
        return [Book(*row) for row in raw_data]

    def _get_members(self):
        raw_data = read_data(MEMBERS_FILE)
        # Handle cases where borrowed_books column might be empty
        return [Member(row[0], row[1], row[2], row[3] if len(row) > 3 else "") for row in raw_data]

    def add_book(self, book_id, title, author, category):
        try:
            books = self._get_books()
        except FileNotFoundException:
            books = [] # If file missing, create new list to start saving
            
        new_book = Book(book_id, title, author, category)
        books.append(new_book)
        write_data(BOOKS_FILE, books)
        print("Book added successfully")

    def view_books(self):
        books = self._get_books()
        print("\nAvailable Books")
        for b in books:
            print(f"Book ID : {b.book_id}\nTitle : {b.title}\nAuthor : {b.author}\nStatus : {b.status}")

    def register_member(self, member_id, name, email):
        try:
            members = self._get_members()
        except FileNotFoundException:
            members = []
            
        new_member = Member(member_id, name, email)
        members.append(new_member)
        write_data(MEMBERS_FILE, members)
        print("Member registered successfully.")

    def borrow_book(self, member_id, book_id):
        members = self._get_members()
        books = self._get_books()

        # Find Member
        member = next((m for m in members if m.member_id == member_id), None)
        if not member:
            raise MemberNotFoundException("Error: Member not found.")

        # Find Book
        book = next((b for b in books if b.book_id == book_id), None)
        if not book:
            raise BookNotFoundException("Error: Book not found in the library.")

        # Check Availability
        if book.status == "Borrowed":
            raise BookAlreadyBorrowedException("Error: Book is currently not available.")

        # Update Statuses
        book.status = "Borrowed"
        member.borrowed_books.append(book_id)

        # Save files
        write_data(BOOKS_FILE, books)
        write_data(MEMBERS_FILE, members)
        print("Book borrowed successfully.")

    def return_book(self, member_id, book_id):
        members = self._get_members()
        books = self._get_books()

        # Find Member
        member = next((m for m in members if m.member_id == member_id), None)
        if not member:
            raise MemberNotFoundException("Error: Member not found.")

        # Check if member borrowed this book
        if book_id not in member.borrowed_books:
            raise BookNotBorrowedByMemberException("Error: Book not borrowed by this member.")

        # Find Book
        book = next((b for b in books if b.book_id == book_id), None)
        if not book:
            raise BookNotFoundException("Error: Book not found.")

        # Update Statuses
        book.status = "Available"
        member.borrowed_books.remove(book_id)

        # Save files
        write_data(BOOKS_FILE, books)
        write_data(MEMBERS_FILE, members)
        print("Book returned successfully.")

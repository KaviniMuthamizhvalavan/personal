from services.library_system import LibrarySystem

def main():
    library = LibrarySystem()
    
    member = library.add_member("M001", "Alice Smith", 28, "regular")
    print(f"Added Member: {member.name}, Type: {member.membership_type}")

    book1 = library.add_book("B001", "1984", "George Orwell", "Dystopian")
    book2 = library.add_book("B002", "To Kill a Mockingbird", "Harper Lee", "Fiction")
    print(f"Added Book: {book1.title} (Available: {book1.is_available})")
    print(f"Added Book: {book2.title} (Available: {book2.is_available})")

    borrow_record = library.borrow_book("R001", "M001", "B001", date(2026, 7, 19))

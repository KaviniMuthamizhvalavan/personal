import pytest
from services.borrow_service import BorrowService
from services.book_service import BookService
from services.member_service import MemberService

@pytest.fixture
def setup_services():
    test_datastore = {"members": {}, "books": {}, "borrows": {}}
    book_service = BookService(test_datastore)
    member_service = MemberService(test_datastore)
    borrow_service = BorrowService(test_datastore, book_service, member_service)
    return borrow_service, book_service, member_service, test_datastore

def test_borrow_book(setup_services):
    borrow_service, book_service, member_service, datastore = setup_services
    member_service.add_member("M001", "Alice", 25, "regular")
    book_service.add_book("B001", "Dune", "Frank Herbert", "Sci-Fi")
    
    record = borrow_service.borrow_book("R001", "M001", "B001", date(2026, 7, 19))
    assert record.id == "R001"
    assert datastore["borrows"]["R001"] == record
    assert datastore["books"]["B001"].is_available is False

def test_borrow_unavailable_book_raises_error(setup_services):
    borrow_service, book_service, member_service, _ = setup_services
    member_service.add_member("M001", "Alice", 25, "regular")
    book_service.add_book("B001", "Dune", "Frank Herbert", "Sci-Fi", is_available=False)
    
    with pytest.raises(ValueError):
        borrow_service.borrow_book("R001", "M001", "B001", date(2026, 7, 19))

def test_return_book(setup_services):
    borrow_service, book_service, member_service, datastore = setup_services
    member_service.add_member("M001", "Alice", 25, "regular")
    book_service.add_book("B001", "Dune", "Frank Herbert", "Sci-Fi")
    borrow_service.borrow_book("R001", "M001", "B001", date(2026, 7, 19))
    
    record = borrow_service.return_book("R001", date(2026, 7, 26))
    assert record.return_date == date(2026, 7, 26)
    assert datastore["books"]["B001"].is_available is True

def test_delete_record(setup_services):
    borrow_service, book_service, member_service, datastore = setup_services
    member_service.add_member("M001", "Alice", 25, "regular")
    book_service.add_book("B001", "Dune", "Frank Herbert", "Sci-Fi")
    borrow_service.borrow_book("R001", "M001", "B001", date(2026, 7, 19))
    
    result = borrow_service.delete_record("R001")

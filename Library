    print(f"Updated Availability for '{book1.title}': {library.get_book('B001').is_available}")

    return_record = library.return_book("R001", date(2026, 7, 26))
    print(f"Book Returned on: {return_record.return_date}")
    print(f"Updated Availability for '{book1.title}': {library.get_book('B001').is_available}")


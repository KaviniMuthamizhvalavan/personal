from datetime import date
from models.borrow_record import BorrowRecord
from utils.validator import is_book_available

class BorrowService:
    def __init__(self, datastore: dict, book_service, member_service):
        self.datastore = datastore
        self.book_service = book_service
        self.member_service = member_service

    def borrow_book(self, borrow_id: str, member_id: str, book_id: str, borrow_date: date) -> BorrowRecord:
        member = self.member_service.get_member(member_id)
        if not member:
            raise KeyError("Member not found")
        book = self.book_service.get_book(book_id)
        if not is_book_available(book):
            raise ValueError("Book is not available")
        if borrow_id in self.datastore["borrows"]:
            raise ValueError("Borrow ID already exists")

        record = BorrowRecord(borrow_id, member_id, book_id, borrow_date)
        self.datastore["borrows"][borrow_id] = record
        self.book_service.update_availability(book_id, False)
        return record

    def return_book(self, borrow_id: str, return_date: date) -> BorrowRecord:
        record = self.datastore["borrows"].get(borrow_id)
        if not record:
            raise KeyError("Borrow record not found")
        if record.return_date is not None:
            raise ValueError("Book already returned")

        record.return_date = return_date
        self.book_service.update_availability(record.book_id, True)
        return record

    def delete_record(self, borrow_id: str) -> bool:
        if borrow_id in self.datastore["borrows"]:
            del self.datastore["borrows"][borrow_id]
            return True
        return False

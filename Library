def validate_membership_type(membership_type: str) -> bool:
    valid_types = {"regular", "premium", "student"}
    return membership_type.lower() in valid_types

def is_book_available(book: Book) -> bool:
    return book is not None and book.is_available
from models.member import Member
from utils.validator import validate_membership_type

class MemberService:
    def __init__(self, datastore: dict):
        self.datastore = datastore

    def add_member(self, member_id: str, name: str, age: int, membership_type: str) -> Member:
        if not validate_membership_type(membership_type):
            raise ValueError("Invalid membership type")
        if member_id in self.datastore["members"]:
            raise ValueError("Member ID already exists")
        member = Member(member_id, name, age, membership_type)
        self.datastore["members"][member_id] = member
        return member

    def get_member(self, member_id: str) -> Member:
        return self.datastore["members"].get(member_id)

    def update_membership(self, member_id: str, new_membership_type: str) -> Member:
        if not validate_membership_type(new_membership_type):
            raise ValueError("Invalid membership type")
        member = self.get_member(member_id)
        if not member:
            raise KeyError("Member not found")
        member.membership_type = new_membership_type
        return member

    def delete_member(self, member_id: str) -> bool:
        if member_id in self.datastore["members"]:
            del self.datastore["members"][member_id]
            return True
        return False
